---
import { canonicalUrl, site } from "../site";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  type?: "website" | "article";
}

const { title, description, canonicalPath, type = "website" } = Astro.props;
const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
const canonical = canonicalUrl(canonicalPath);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary" />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} RSS`} href="/rss.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: site.name,
      url: site.url,
      description: site.description
    })} />
    {site.analyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${site.analyticsToken}"}`}
      />
    )}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${site.name} home`}>
        <span class="brand-mark">WL</span>
        <span>{site.name}</span>
      </a>
      <nav aria-label="Main navigation">
        <a href="/light-meter/">Light tool</a>
        <a href="/plant-distance-calculator/">Calculator</a>
        <a href="/north-facing-window-plants/">Guides</a>
        <a href="/about/">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>{site.name} publishes practical, evidence-labeled houseplant placement resources.</p>
      <nav aria-label="Footer navigation">
        <a href="/editorial-policy/">Editorial policy</a>
        <a href="/privacy/">Privacy</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #1e2621;
    --muted: #59655d;
    --line: #d8dfd6;
    --paper: #fbfcf8;
    --surface: #ffffff;
    --leaf: #2f7d4f;
    --moss: #7d9658;
    --sun: #f1b84a;
    --clay: #b76542;
    --sky: #d8ecf6;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-size: 17px;
    line-height: 1.65;
  }

  a {
    color: #246a43;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  img,
  svg {
    max-width: 100%;
  }

  .site-header,
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 18px 0;
  }

  .site-header {
    border-bottom: 1px solid var(--line);
  }

  .site-footer {
    align-items: flex-start;
    border-top: 1px solid var(--line);
    margin-top: 56px;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .brand,
  nav {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .brand {
    color: var(--ink);
    font-weight: 800;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    background: var(--leaf);
    color: white;
    font-size: 0.82rem;
    letter-spacing: 0;
  }

  nav a {
    color: var(--muted);
    font-size: 0.95rem;
    text-decoration: none;
  }

  main {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: 38px;
    align-items: center;
    min-height: 560px;
    padding: 44px 0 32px;
  }

  .eyebrow {
    color: var(--clay);
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    line-height: 1.15;
    letter-spacing: 0;
  }

  h1 {
    max-width: 780px;
    margin: 0.2em 0;
    font-size: clamp(2.45rem, 5vw, 5rem);
  }

  h2 {
    margin-top: 2.2em;
    font-size: clamp(1.65rem, 3vw, 2.4rem);
  }

  h3 {
    margin-top: 1.8em;
    font-size: 1.25rem;
  }

  .lede {
    max-width: 720px;
    color: var(--muted);
    font-size: 1.18rem;
  }

  .actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    border-radius: 6px;
    padding: 0.72rem 1rem;
    background: var(--leaf);
    color: white;
    font-weight: 750;
    text-decoration: none;
  }

  .button.secondary {
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--ink);
  }

  .panel,
  .tool-panel,
  .callout {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
  }

  .panel,
  .tool-panel {
    padding: 22px;
  }

  .callout {
    padding: 18px;
    border-left: 5px solid var(--sun);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .two-column {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 28px;
    align-items: start;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    background: var(--surface);
  }

  th,
  td {
    border: 1px solid var(--line);
    padding: 0.75rem;
    text-align: left;
    vertical-align: top;
  }

  th {
    background: #eef5ea;
  }

  input,
  select {
    width: 100%;
    min-height: 44px;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.5rem 0.65rem;
    font: inherit;
  }

  label {
    display: grid;
    gap: 0.35rem;
    color: var(--muted);
    font-weight: 700;
  }

  .result {
    min-height: 84px;
    border-radius: 8px;
    padding: 18px;
    background: #eef5ea;
    color: var(--ink);
    font-weight: 750;
  }

  .content {
    max-width: 820px;
    padding-top: 28px;
  }

  .content li + li {
    margin-top: 0.35rem;
  }

  @media (max-width: 760px) {
    .site-header,
    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero,
    .two-column,
    .grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding-top: 30px;
    }
  }
</style>
