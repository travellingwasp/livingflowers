---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Privacy"
  description="Privacy-friendly analytics policy for WindowPlant Lab."
  canonicalPath="/privacy/"
>
  <article class="content">
    <h1>Privacy</h1>
    <p>
      WindowPlant Lab is designed to use Cloudflare Web Analytics, a privacy-friendly analytics product that does not
      require client-side tracking cookies. The analytics token is injected only when configured with
      <code>PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN</code>.
    </p>
    <p>
      The experiment owner should exclude their own visits where possible and avoid collecting unnecessary personal data.
    </p>
  </article>
</BaseLayout>
