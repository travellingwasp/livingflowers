---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Plant Distance From Window Calculator"
  description="Calculate a conservative houseplant distance from a window based on direction, target light level, and common obstruction."
  canonicalPath="/plant-distance-calculator/"
>
  <section class="content">
    <p class="eyebrow">Placement calculator</p>
    <h1>Plant Distance From Window Calculator</h1>
    <p class="lede">Pick the target light level and get a starting distance range you can test for two weeks.</p>
  </section>

  <section class="tool-panel">
    <div class="two-column">
      <form id="distance-form" class="panel">
        <label>
          Window direction
          <select name="direction">
            <option value="north">North</option>
            <option value="east">East</option>
            <option value="south">South</option>
            <option value="west">West</option>
          </select>
        </label>
        <label>
          Target plant light
          <select name="target">
            <option value="low">Low tolerant</option>
            <option value="medium">Medium</option>
            <option value="bright">Bright indirect</option>
          </select>
        </label>
        <label>
          Obstruction
          <select name="shade">
            <option value="clear">Clear sky view</option>
            <option value="partial">Partly blocked</option>
            <option value="heavy">Heavily blocked</option>
          </select>
        </label>
      </form>
      <div>
        <p id="distance-result" class="result" aria-live="polite"></p>
        <p>
          Treat the result as a placement hypothesis. The plant's new growth is the validation metric.
        </p>
      </div>
    </div>
  </section>

  <section class="content">
    <h2>Distance ranges to test</h2>
    <table>
      <thead><tr><th>Condition</th><th>First test</th><th>Watch for</th></tr></thead>
      <tbody>
        <tr><td>North window</td><td>0-4 ft for most foliage plants</td><td>Stretching if placed too far back</td></tr>
        <tr><td>East window</td><td>1-6 ft for medium to bright-indirect plants</td><td>Morning sun on delicate leaves</td></tr>
        <tr><td>South or west window</td><td>3-10 ft or filtered light</td><td>Scorch near hot glass</td></tr>
      </tbody>
    </table>
  </section>

  <script>
    const form = document.querySelector("#distance-form");
    const output = document.querySelector("#distance-result");
    const table: Record<string, Record<string, string>> = {
      north: { low: "2-8 ft", medium: "0-4 ft", bright: "within 2 ft, usually with clear sky view" },
      east: { low: "5-12 ft", medium: "2-7 ft", bright: "0-4 ft" },
      south: { low: "8-14 ft", medium: "4-10 ft", bright: "2-6 ft or behind a sheer curtain" },
      west: { low: "8-14 ft", medium: "5-10 ft", bright: "3-7 ft or filtered from hot afternoon sun" }
    };

    function updateDistance() {
      if (!(form instanceof HTMLFormElement) || !output) return;
      const data = new FormData(form);
      const direction = String(data.get("direction"));
      const target = String(data.get("target"));
      const shade = String(data.get("shade"));
      const base = table[direction]?.[target] || "start close to the window and observe growth";
      const caveat =
        shade === "heavy"
          ? " Because this view is heavily blocked, move one zone closer or add a grow light."
          : shade === "partial"
            ? " Because the view is partly blocked, start near the closer end of the range."
            : " Recheck after two weeks of new growth.";
      output.textContent = `Start at ${base}.${caveat}`;
    }

    form?.addEventListener("input", updateDistance);
    updateDistance();
  </script>
</BaseLayout>
